# LLM backend
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=

# Optional tuning
WHISPER_MODEL_SIZE=tiny
CLIP_MIN_SECONDS=15
CLIP_MAX_SECONDS=40
MAX_CLIPS=15
TARGET_WIDTH=1080
TARGET_HEIGHT=1920
FFMPEG_PRESET=veryfast
ENABLE_SUBTITLES=true
SKIP_SCENE_DETECTION=true
MAX_PARALLEL_CLIPS=4
YT_SC_OUTPUT_DIR=output
YT_SC_CACHE_DIR=.cache

# Optional archive upload
AUTO_UPLOAD=false
UPLOAD_PROVIDER=gdrive
UPLOAD_PATH=shorts
DELETE_ZIP_AFTER_UPLOAD=false
